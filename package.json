{
  "name": "sport-rent-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "type-check": "tsc --noEmit",
    "format": "oxfmt --write \"**/*.{js,jsx,ts,tsx}\"",
    "format-check": "oxfmt --check \"**/*.{js,jsx,ts,tsx}\"",
    "preview": "vite preview"
  },
  "dependencies": {
    "oxfmt": "^0.57.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "oxlint": "^1.71.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
